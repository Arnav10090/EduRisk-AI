# ============================================
# EduRisk AI - Docker Ignore File
# Excludes unnecessary files from Docker context
# ============================================

# ============================================
# Version Control
# ============================================
.git/
.gitignore
.gitattributes
.github/

# ============================================
# Documentation
# ============================================
*.md
!README.md
docs/
.kiro/

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environments
venv/
env/
ENV/
.venv/
.virtualenv/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
test_data/
tests/
*_test.py
test_*.py

# Distribution
dist/
build/
*.egg-info/

# ============================================
# Node.js / Frontend
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/
.turbo/
.cache/

# ============================================
# Environment & Secrets
# ============================================
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# ============================================
# ML Models & Data (Build separately)
# ============================================
ml/models/*.pkl
ml/models/*.joblib
ml/data/synthetic/*.csv
ml/data/raw/*.csv
ml/data/processed/*.csv

# Keep essential model files
!ml/models/version.json
!ml/models/feature_names.json

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3
*.dump

# ============================================
# IDEs
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Logs
# ============================================
*.log
logs/

# ============================================
# Docker
# ============================================
Dockerfile*
docker-compose*.yml
.dockerignore

# ============================================
# CI/CD
# ============================================
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# ============================================
# Temporary Files
# ============================================
*.tmp
*.temp
*.bak
*.backup
tmp/
temp/

# ============================================
# Coverage Reports
# ============================================
htmlcov/
coverage/
.coverage

# ============================================
# Miscellaneous
# ============================================
*.zip
*.tar.gz
*.rar
LICENSE
CHANGELOG.md
CONTRIBUTING.md
