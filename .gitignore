# ============================================
# Keep Important Files
# ============================================
# Ensure these are NOT ignored
!.gitkeep
!.gitignore
!README.md
!requirements.txt
!package.json
!docker-compose.yml
!Dockerfile
!.dockerignore
!pyproject.toml
!setup.py
!setup.cfg
!MANIFEST.in
!LICENSE
!.editorconfig
!.pre-commit-config.yaml

# ============================================
# Additional Exclusions
# ============================================
# Ignore everything in data directories except .gitkeep
ml/data/synthetic/*
!ml/data/synthetic/.gitkeep

ml/data/raw/*
!ml/data/raw/.gitkeep

ml/data/processed/*
!ml/data/processed/.gitkeep

ml/data/external/*
!ml/data/external/.gitkeep

# Ignore reports but keep structure
ml/reports/figures/*
!ml/reports/figures/.gitkeep

# Ignore logs but keep directory
logs/*
!logs/.gitkeep

# Ignore uploads but keep directory
uploads/*
!uploads/.gitkeep

# Ignore downloads but keep directory
downloads/*
!downloads/.gitkeep

# ============================================
# Security - Double Check
# ============================================
# Ensure these are NEVER committed
**/.env
**/.env.local
**/.env.*.local
**/config.json
**/*.key
**/*.pem
**/*.p12
**/*.pfx
**/secrets.json
**/credentials.json
**/*_rsa
**/*_dsa
**/*_ecdsa
**/*_ed25519
**/.aws/
**/.azure/
**/.gcloud/

# ============================================
# End of .gitignore
# ============================================
