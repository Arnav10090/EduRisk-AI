# ============================================
# ML Models and Data
# ============================================
# Trained models - ignore all model binaries
ml/models/*.pkl
ml/models/*.joblib
ml/models/*.h5
ml/models/*.pt
ml/models/*.pth
ml/models/*.onnx
ml/models/*.pb

# But keep these metadata files (use ! to negate)
!ml/models/version.json
!ml/models/feature_names.json
!ml/models/training_metrics.json
!ml/models/salary_metrics.json
!ml/models/.gitkeep

# Data files
ml/data/synthetic/*.csv
ml/data/raw/*.csv
ml/data/processed/*.csv
ml/data/external/*.csv
ml/data/**/*.parquet
ml/data/**/*.feather

# Keep .gitkeep files
!ml/data/**/.gitkeep

# ML experiment tracking
mlruns/
runs/
wandb/
.neptune/

# Model checkpoints
checkpoints/
*.ckpt

# SHAP plots and visualizations
ml/reports/figures/*.png
ml/reports/figures/*.jpg
ml/reports/*.html

# Optuna database
optuna.db

